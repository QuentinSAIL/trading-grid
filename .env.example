# Copier ce fichier en .env et remplir les valeurs

# Exchange (ex: mexc, kucoin, gate, bitget — sans KYC jusqu'à ~1000€/j)
EXCHANGE=mexc
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# Paire de trading (fortement volatile, liquide)
SYMBOL=BTC/USDT

# Capital à allouer au bot (en USDT)
CAPITAL=80

# Paramètres de la grille
GRID_LEVELS=10          # Nombre de niveaux dans la grille
GRID_SPREAD=0.005       # 0.5% entre chaque niveau (0.003=0.3% agressif, 0.01=1% conservateur)
PRICE_RANGE_PCT=0.05    # ±5% autour du prix actuel pour placer la grille

# Gestion du risque
STOP_LOSS_PCT=0.08      # Stop loss global à -8% du capital
MAX_OPEN_ORDERS=20      # Nombre max d'ordres ouverts simultanément

# Discord webhook pour les rapports (optionnel)
DISCORD_WEBHOOK=https://discord.com/api/webhooks/your_webhook_here

# Mode paper trading (true = simulation, false = réel)
PAPER_TRADING=true
