# Copier ce fichier en .env et remplir les valeurs

# Exchange (ex: mexc, kucoin, gate, bitget — sans KYC jusqu'à ~1000€/j)
EXCHANGE=mexc
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# Paire de trading (fortement volatile, liquide)
SYMBOL=BTC/USDT

# Pourcentage du portefeuille à allouer au bot (auto-compound)
CAPITAL_ALLOCATION=99

# Paramètres de la grille (optimises par sweep sur 1000j)
GRID_LEVELS=8           # 8 niveaux (sweet spot activite/risque)
GRID_SPREAD=0.003       # 0.3% base — le spread dynamique monte avec la volatilite
PRICE_RANGE_PCT=0.05    # Recentrage a 5% de drift

# Gestion du risque
STOP_LOSS_PCT=0.50      # Stop loss a 50% (laisser la grille travailler)
MAX_OPEN_ORDERS=20      # Nombre max d'ordres ouverts simultanément
MAKER_FEE=0.0           # Frais maker par ordre (0% pour MEXC)
TAKER_FEE=0.001         # Frais taker par ordre (0.1% pour MEXC)

# Discord webhook pour les rapports (optionnel)
DISCORD_WEBHOOK=https://discord.com/api/webhooks/your_webhook_here

# Mode paper trading (true = simulation, false = réel)
PAPER_TRADING=true
