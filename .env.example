# Copier ce fichier en .env et remplir les valeurs

# Exchange (ex: mexc, kucoin, gate, bitget — sans KYC jusqu'à ~1000€/j)
EXCHANGE=mexc
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here

# Paire de trading (fortement volatile, liquide)
SYMBOL=BTC/USDT

# Pourcentage du portefeuille à allouer au bot (auto-compound)
CAPITAL_ALLOCATION=99

# Paramètres de la grille (optimises par sweep H - 0.246%/j@100j, 0.063%/j@200j)
GRID_LEVELS=3            # 3 niveaux ultra-concentres
GRID_SPREAD=0.008        # 0.8% base — spread dynamique BB adapte la volatilite
PRICE_RANGE_PCT=0.04     # Recentrage a 4% de drift (robuste bear market)

# Grille avancee
GRID_TYPE=geometric      # geometric ou linear
WEIGHT_FACTOR=-0.9       # negatif = plus de capital sur niveaux proches (cycling rapide)

# Indicateurs
RSI_PERIOD=14            # Periode RSI
RSI_STRENGTH=4.0         # 4.0=ultra agressif — boost buys survendu / sells surachete
EMA_FAST=12              # EMA rapide (periodes)
EMA_SLOW=26              # EMA lente (periodes)
EMA_STRENGTH=0           # off — pas de filtre tendance
BB_PERIOD=20             # Periode Bollinger Bands
BB_MULT=2.0              # Multiplicateur BB
BB_SPREAD_ADAPT=true     # Adapter le spread a la largeur BB

# Gestion du risque
STOP_LOSS_PCT=0.25       # Stop loss a 25% (rarement trigger)
MIN_CAPITAL=30            # Capital minimum USDT (bot s'arrete en dessous)
MAX_OPEN_ORDERS=20       # Nombre max d'ordres ouverts simultanement
MAKER_FEE=0.0            # Frais maker par ordre (0% pour MEXC)
TAKER_FEE=0.001          # Frais taker par ordre (0.1% pour MEXC)

# Stale order decay (libere l'inventaire en bear market)
STALE_HOURS=72            # Heures avant que les contre-ordres decay
DECAY_PER_HOUR=0.0008     # Reduction prix par heure apres stale (0.08%/h)

# Trend-adaptive spread (elargit en tendance forte)
TREND_SPREAD_MULT=0       # 0=off

# Drawdown protection (reduit les tailles quand ca va mal)
DD_THRESHOLD=1.0          # 1.0=off
DD_FACTOR=0.5             # Facteur reduction si DD > seuil

# Inventory cap (empeche suraccumulation BTC)
MAX_INV_RATIO=0.20        # Max BTC en % du portefeuille (tres conservateur)
INITIAL_BTC_PCT=0.25      # Allocation initiale BTC 25%

# Fear & Greed Index (live bot uniquement)
FEAR_GREED_ENABLED=true   # Acheter pendant la peur, vendre pendant la cupidite

# Discord webhook pour les rapports (optionnel)
DISCORD_WEBHOOK=https://discord.com/api/webhooks/your_webhook_here

# Mode paper trading (true = simulation, false = réel)
PAPER_TRADING=true
